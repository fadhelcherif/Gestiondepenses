@model C__GestionDepenses.Models.AdminDashboardViewModel

@{
    ViewData["Title"] = "My statistics";
    var me = Model.Users.FirstOrDefault();
    var now = DateTime.Now;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0">My statistics</h1>
    <a class="btn btn-outline-primary" asp-controller="Dashboard" asp-action="ExportMonthlyPdf" asp-route-year="@now.Year" asp-route-month="@now.Month">Export PDF (this month)</a>
</div>

@if (me == null)
{
    <div class="alert alert-warning">No data.</div>
}
else
{
    <div class="row mb-3">
        <div class="col-md-4">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">This month Revenus</h5>
                    <p class="card-text fw-bold">@me.ThisMonthRevenus</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">This month Dépenses</h5>
                    <p class="card-text fw-bold">@me.ThisMonthDepenses</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">This month Balance</h5>
                    <p class="card-text fw-bold @(me.ThisMonthBalance >= 0 ? "text-success" : "text-danger")">@me.ThisMonthBalance</p>
                    <small class="text-muted">@(me.ThisMonthBalance >= 0 ? "Gain" : "Déficit")</small>
                </div>
            </div>
        </div>
    </div>

    <div class="row mb-3">
        <div class="col-md-4">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">Total Revenus</h5>
                    <p class="card-text fw-bold">@me.TotalRevenus</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">Total Dépenses</h5>
                    <p class="card-text fw-bold">@me.TotalDepenses</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">Balance</h5>
                    <p class="card-text fw-bold @(me.Balance >= 0 ? "text-success" : "text-danger")">@me.Balance</p>
                    <small class="text-muted">@(me.Balance >= 0 ? "Gain" : "Déficit")</small>
                </div>
            </div>
        </div>
    </div>

    <div class="row mb-3">
        <div class="col-md-6">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">Top Dépense</h5>
                    @if (me.TopDepenseMontant.HasValue)
                    {
                        <p class="card-text fw-bold">@me.TopDepenseMontant</p>
                        <small class="text-muted">@me.TopDepenseCategorie - @me.TopDepenseDescription</small>
                    }
                    else
                    {
                        <p class="card-text text-muted">No expenses yet.</p>
                    }
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">Top Revenu</h5>
                    @if (me.TopRevenuMontant.HasValue)
                    {
                        <p class="card-text fw-bold">@me.TopRevenuMontant</p>
                        <small class="text-muted">@me.TopRevenuCategorie - @me.TopRevenuDescription</small>
                    }
                    else
                    {
                        <p class="card-text text-muted">No income yet.</p>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="card mb-3">
        <div class="card-body">
            <h5 class="card-title">Budget progress (this month)</h5>
            @if (me.BudgetsThisMonth == null || me.BudgetsThisMonth.Count == 0)
            {
                <p class="text-muted mb-0">No budgets configured (no categories with seuil).</p>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-sm align-middle">
                        <thead>
                            <tr>
                                <th>Category</th>
                                <th class="text-end">Spent</th>
                                <th class="text-end">Seuil</th>
                                <th style="width:40%">Progress</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var b in me.BudgetsThisMonth)
                            {
                                var percentRaw = b.PercentUsed;
                                var percent = percentRaw < 0 ? 0 : percentRaw;
                                var percentClamped = percent > 100 ? 100 : percent;
                                var barClass = b.IsOver ? "bg-danger" : (percentRaw >= 80 ? "bg-warning" : "bg-success");

                                <tr>
                                    <td>@b.CategoryName</td>
                                    <td class="text-end">@b.SpentThisMonth</td>
                                    <td class="text-end">@b.Seuil</td>
                                    <td>
                                        <div class="progress" style="height: 18px;">
                                            <div class="progress-bar @barClass" role="progressbar" style="width: @percentClamped.ToString("0")%" aria-valuenow="@percentClamped" aria-valuemin="0" aria-valuemax="100">
                                                @percentRaw.ToString("0")%
                                            </div>
                                        </div>
                                        @if (b.IsOver)
                                        {
                                            <small class="text-danger">Over budget by @(-b.Remaining)</small>
                                        }
                                        else
                                        {
                                            <small class="text-muted">Remaining @b.Remaining</small>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
}
